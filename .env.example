# ═════════════════════════════════════════════════════════════════
# TELENYX AI RECEPTIONIST GATEWAY - ENVIRONMENT CONFIGURATION
# ═════════════════════════════════════════════════════════════════

# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────
# SUPABASE (Database & Real-Time)
# ─────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# ─────────────────────────────────────────────────────────────────
# GOOGLE GEMINI (AI Model)
# ─────────────────────────────────────────────────────────────────
# Get this from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...your-gemini-api-key...
VITE_GEMINI_API_KEY=AIzaSy...your-gemini-api-key...

# ─────────────────────────────────────────────────────────────────
# TELNYX (Phone Integration)
# ─────────────────────────────────────────────────────────────────
# Get these from: https://portal.telnyx.com/account/settings
TELNYX_API_KEY=KEY...your-telnyx-api-key...
TELNYX_PUBLIC_KEY=PK...your-telnyx-public-key...
TELNYX_SIP_USERNAME=sip_username
TELNYX_SIP_PASSWORD=sip_password

# ─────────────────────────────────────────────────────────────────
# STRIPE (Payment Processing - Optional, not yet implemented)
# ─────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MINUTE_PACK_PRICE_ID=price_...
STRIPE_SUBSCRIPTION_PRICE_ID=price_...

# ─────────────────────────────────────────────────────────────────
# RESEND (Email Notifications - Optional, not yet implemented)
# ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...